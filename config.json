{
  "watch_directory": "~/Documents/File Organiser",
  "settle_seconds": 3,
  "rules": {
    "CollegeDocs": {
      "extensions": [
        ".pdf",
        ".docx",
        ".txt",
        ".doc"
      ],
      "keywords": [
        "assign",
        "assignment",
        "ass",
        "project",
        "report"
      ]
    },
    "Images": {
      "extensions": [
        ".jpg",
        ".jpeg",
        ".png",
        ".gif",
        ".webp"
      ],
      "keywords": []
    },
    "GeneralDocs": {
      "extensions": [],
      "keywords": []
    },
    "Code": {
      "extensions": [
        ".py",
        ".js",
        ".cpp",
        ".c",
        ".html",
        ".css",
        ".json"
      ],
      "keywords": []
    },
    "projects": {
      "extensions": [
        ".html",
        ".py",
        ".txt"
      ],
      "keywords": [
        "project",
        "pro",
        "prjct",
        "pp",
        "proj"
      ]
    },
    "anime": {
      "extensions": [
        ".pdf",
        ".png",
        ".txt",
        ".html"
      ],
      "keywords": [
        "demo",
        "dem",
        "gem"
      ]
    },
    "failure": {
      "extensions": [
        ".html",
        ".txt",
        ".py"
      ],
      "keywords": [
        "ran",
        "rat",
        "race"
      ]
    }
  },
  "destinations": {
    "CollegeDocs": "~/Documents/File Organiser/College_Assignments",
    "Images": "~/Documents/File Organiser/Images",
    "GeneralDocs": "~/Documents/File Organiser/General",
    "Code": "~/Documents/File Organiser/Development",
    "Others": "~/Documents/File Organiser/Unsorted",
    "projects": "~/Documents/File Organiser/Projects",
    "anime": "~/Documents/File Organiser/mine",
    "failure": "~/Documents/File Organiser/tmp"
  }
}